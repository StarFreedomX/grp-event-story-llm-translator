# ==================== CDN / 游戏资源 ====================
# Unity 版本（来自游戏请求头 UnityPlayer/2022.3.62f1）
UNITY_VERSION=2022.3.62f1

# AES 加密常量（API 响应解密）
AES_KEY=''
AES_IV=''

# 客户端版本号 fallback（iTunes 获取失败时使用）
CLIENT_VERSION_FALLBACK=10.1.2

# 数据版本号 fallback（官方 API 获取失败时使用；留空则必须 API 成功）
DATA_VERSION_FALLBACK=10.1.0.190

# 是否保留中间文件（JSON / AssetBundle）
KEEP_TEMP=true

# ==================== 机翻（Machine Translation） ====================
# 是否启用机翻（true / false）
MT_ENABLED=false

# 服务商：openai | anthropic | deepseek | gemini | qwen
# 实际使用的 HTTP 协议看 MT_API_FORMAT
MT_PROVIDER=openai

# API 格式：openai 或 anthropic（HTTP 协议层面）
MT_API_FORMAT=openai

# API 地址
MT_BASE_URL=https://api.openai.com/v1

# API Key（机翻启用时必填）
MT_API_KEY=

# 模型名称
MT_MODEL=gpt-4o-mini

# 思考模式：disabled | auto | enabled
MT_REASONING_MODE=disabled

# 思考强度：auto | low | medium | high | max
MT_REASONING_EFFORT=auto

# 温度（0.0~2.0）
MT_TEMPERATURE=0.3

# 额外提示词文件名（放在项目根目录，留空或文件不存在则不使用）
MT_FURTHER_PROMPT_FILE=further_prompt.md
